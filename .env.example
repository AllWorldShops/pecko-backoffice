# ── Database ─────────────────────────────────────────────────────────────────
# SQLite — a single file inside the project, no server needed.
DATABASE_URL="file:./pecko.db"

# ── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-string
JWT_REFRESH_SECRET=change-me-to-another-long-random-string

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ── HTTPS ─────────────────────────────────────────────────────────────────────
# Set to true ONLY if your server is behind HTTPS/TLS (e.g., nginx with SSL).
# Leave false for plain HTTP on a local/internal network.
HTTPS=false

# ── CORS ──────────────────────────────────────────────────────────────────────
# In production, set this to the URL users access the app on.
# If Express serves both frontend + backend (default), use the server's own URL.
# Example for LAN:  http://192.168.1.50:3001
# Example for dev:  http://localhost:5173
CLIENT_URL=http://localhost:3001

# ── File storage ──────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
LOG_LEVEL=info
